###############################################################################
# kinextract.config
#
# Template TOML configuration file for kinextract. Copy this to your own
# extraction directory, adjust the paths and galaxy-specific values below,
# and pass it to the CLI entry point:
#
#   python -m kinextract /path/to/spectrum.spec /path/to/kinextract.config
#   # or, after `pip install kinextract`:
#   kinextract /path/to/spectrum.spec /path/to/kinextract.config
#
# For notebook/scripted use, load it directly instead:
#
#   from kinextract import load_config_from_toml, run_spectral_fit
#   cfg = load_config_from_toml("kinextract.config")
#   fit = run_spectral_fit(cfg, gal_file="/path/to/spectrum.spec")
#
# TOML section names below ([wavelength], [kinematics], ...) are purely
# organizational -- kinextract flattens all of them into a single FitConfig
# namespace, so the section a field lives in here doesn't matter. This
# file only shows the fields most commonly tuned per-galaxy; the full set
# is documented on FitConfig itself -- run FitConfig.describe() (optionally
# with a substring filter, e.g. FitConfig.describe("als")) to print every
# tunable field grouped by subsystem, or see the FitConfig class docstring.
###############################################################################


[paths]

# Path to a file listing template spectra, one per line (paths resolved
# relative to template_dir if given). Any number of templates is
# supported -- there is nothing library-specific hard-coded here, so you
# can point this at your own template set (MILES, E-MILES, a handful of
# individually-selected stars, etc.).
template_list_file = "/path/to/your/templates/Tlist"
template_dir = "/path/to/your/templates/"
regions_bad_path = ""
outdir = "/path/to/your/output/directory/"

# Optional: point at a legacy galaxy.params file to auto-populate
# losvd_vmin/vmax from its vmin/vmax entries (see
# use_galaxy_params_velocity_bounds below). Leave empty to set
# losvd_vmin/vmax explicitly under [kinematics] instead.
galaxy_params_path = ""
use_galaxy_params_velocity_bounds = true

# Write {prefix}.fit/.temp/.ascii/.rms to outdir after each fit. Set false
# to keep results in memory only (useful for batch-fitting many spectra
# from a script without touching the filesystem per spectrum).
write_outputs = true

[wavelength]

# wavemin_full/step describe the FULL raw spectrum's pixel grid and are
# only required for raw index-format .spec files (or .norm files with
# fortran_rebin_norm=true). zgal is the galaxy's systemic redshift.
wavemin_full = 4750.0
step = 1.25
wavefitmin = 8400.0
wavefitmax = 8750.0
zgal = 0.0016
norm_wave_frame = "auto"
spec_col3_is_variance = false
# Set false to ignore per-pixel input errors and use the median error uniformly
# (equal pixel weighting).  Error column is still read; only fit weights change.
use_spectrum_errors = true

[kinematics]

# Initial guess for the LOSVD velocity dispersion (km/s); also sets the
# default LOSVD grid width if losvd_vmin/vmax aren't set explicitly above
# or via galaxy_params_path.
sigl = 100.0

# Fixed regularization strength, used only if xlam_auto = false.
xlam = 300.0

# Per-spectrum automatic smoothing-parameter selection: grid-search
# xlam_auto_grid and pick a value per xlam_criterion (see FitConfig
# docstring for the "chi2" vs "roughness" criteria).
xlam_auto = true
xlam_criterion = "chi2"
xlam_auto_grid = [100.0, 1000.0, 10000.0, 100000.0]
xlam_chi2_tolerance = 0.02
xlam_smooth_threshold = 0.25
# Unimodality constraint: reject xlam values whose recovered LOSVD has more
# than xlam_max_peaks prominent peaks (>= xlam_peak_min_prominence * the
# global peak). Catches double-peaked LOSVDs that are fitting artifacts.
xlam_max_peaks = 1
xlam_peak_min_prominence = 0.1
# Reduced iteration budget for search fits (an approximate LOSVD shape is
# enough to judge roughness/peaks; None -> use map_maxiter).
xlam_auto_maxiter = 2000

[continuum]

# false = pre-normalized mode (continuum division already done upstream).
# true  = co-fit an asymmetric-least-squares (ALS) continuum baseline with
#         the LOSVD -- see [als]/[als_optimization]/[als_masks] below.
fit_als_continuum = true

[als]

als_lam = 1.0e7
als_p = 0.05
als_niter = 20
als_outer_iter = 4
als_outer_tol = 1.0e-3
als_eps = 1.0e-6
als_clip = [0.0, "inf"]

[als_optimization]

# Grid-search (als_lam, als_p) instead of using the fixed values above.
als_optimize = false
als_lam_grid = [1.0e2, 1.0e3, 1.0e4, 1.0e5, 1.0e6, 1.0e7, 1.0e8, 1.0e9]
als_p_grid = [0.5]
als_lam_grid_fine_n = 5
als_p_grid_fine_n = 5
als_template_selection = "lsq"
als_use_bic = true
als_bic_dof_penalty = 1.0
als_chisq_floor = 1.0
als_hutchinson_probes = 25
als_opt_verbose = false

[als_masks]

als_mask_ca = true
als_ca_centers = [8498.02, 8542.09, 8662.14]
als_ca_half_widths = [8.0, 8.0, 8.0]
als_ca_frame = "rest"

# Auto-refine the mask center shift using the measured Ca II triplet
# position, so masks track the real features even if zgal is slightly
# off. Masking-only: has no effect on the recovered velocity/LOSVD.
als_auto_caii_shift = true
als_auto_caii_search_hw_A = 12.0

als_extra_mask_windows = []
als_extra_mask_frame = "rest"
als_extra_mask_lines = []
als_extra_mask_line_frame = "rest"

[als_absorption_cleaning]

# pPXF-like iterative sigma-clipping of absorption outliers from the ALS
# continuum fit only (does not touch the LOSVD/template chi-squared fit;
# see [cleaning] below for that).
als_abs_clean = true
als_abs_clean_iter = 25
als_abs_clean_sigma = 3.0
als_abs_clean_grow_A = 3.0
als_abs_clean_two_sided = false
als_abs_clean_minpix = 50
als_abs_clean_init_only = false

[spectral_masking]

# Emission lines are absent from stellar templates; pre-mask them so they
# cannot bias the LOSVD fit even if too weak to be caught by sigma-clipping.
mask_emission_lines_in_fit = true
mask_paschen_lines_in_fit = false
mask_emission_line_half_width_A = 5.0
mask_emission_line_snr_threshold = 3.0
mask_emission_line_snr_context_A = 20.0
mask_emission_grow_A = 0.0

segment_emission_mask = true
segment_emission_n_sigma = 3.0
segment_emission_win_A = 50.0

# Foreground absorption NOT in the templates (e.g. ISM Ca II H&K,
# telluric). Applied to both ALS masking and kinematic clean-protection.
# Format: [[center_A, half_width_A], ...]. Leave empty unless needed.
extra_absorption_lines = []

[losvd]

icoff = 1
coff = 0.0
coff2 = 0.0
n_losvd_bins = 29
fortran_template_mixture = true
fortran_mask_template_outside = true
fit_global_amp = false

[lsf]

# Instrumental line-spread-function (LSF) matching: if the galaxy data
# and template library have different spectral resolution, the sharper
# one is convolved down to match the coarser one before fitting (see
# kinextract.templates.resolution_mismatch_sigma_A). Both fields must be
# set together; leave both commented out (default: both None) to assume
# the two are already matched.
#
# data_fwhm_A must be supplied in the frame given by data_fwhm_frame
# ("observed", the default, or "rest"); template_fwhm_A is always in the
# template library's native (rest-frame) wavelength units.
#
# data_fwhm_A = 2.2
# template_fwhm_A = 2.5
# data_fwhm_frame = "observed"

[optimizer]

map_maxiter = 10000
map_maxfun = 200000
# 1e-10/1e-8 are the current package defaults, validated to give a large
# (roughly 20x) speedup over much tighter tolerances with no measurable
# change in the recovered LOSVD shape -- see FitConfig docstring. Only
# tighten these if you have a specific reason to and re-validate the
# resulting fit quality.
map_ftol = 1.0e-10
map_gtol = 1.0e-8
map_maxls = 50
use_scaled_optimizer = true
print_every = 200

[jax]

# Analytic JAX gradients instead of scipy finite differences: strictly
# more accurate, and for realistic template counts much faster (falls
# back to finite differences automatically if JAX isn't installed).
use_jax_objective = true
jax_enable_x64 = true

[cleaning]

# Iterative sigma-clipping of outlier pixels from the LOSVD/template
# chi-squared fit itself (distinct from als_abs_clean above, which only
# affects the continuum estimate).
clean = true
clean_sigma = 3.0
clean_maxiter = 5
clean_minpix = 10
clean_bloom_pixels = 0

clean_protect_ca_triplet = true
clean_ca_centers = [8498.02, 8542.09, 8662.14]
# Minimum protect half-width (A); automatically widened for broad LOSVDs
# via clean_protect_velocity_pad_kms (see FitConfig docstring).
clean_ca_half_width = 6.0
clean_protect_velocity_pad_kms = 400.0
clean_protect_ca_frame = "rest"
clean_protect_windows = []
clean_protect_windows_frame = "rest"

[errors]

# Consumed by higher-level batch/error-estimation scripts, not FitConfig
# itself -- these keys are recognized by load_config_from_toml() but have
# no effect unless your own driver code reads them.
run_errors_default = true
run_bootstrap_default = true
n_bootstrap = 200
n_jobs = -1
