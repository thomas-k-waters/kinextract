#!/bin/bash

# Function to initialize the directory structure for a galaxy analysis project
# Usage: initialize_directory_structure 'galaxy_name' 'galaxy_data_root'

# Get the directory where this script is located (framework bin directory)
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
framework_root="$(dirname "$script_dir")"

# Source the SCO environment configuration
source "${script_dir}/sco_env.sh"

current_dir=$(pwd)

galaxy_name=$1
galaxy_data_root=$2

if [ "$#" -ne 2 ] || [ -z "$galaxy_name" ] || [ -z "$galaxy_data_root" ]; then
    echo "Error: two arguments are required."
    echo "Usage: initialize_directory_structure 'galaxy_name' 'galaxy_data_root'"
    echo "Example: initialize_directory_structure 'N5102' /home/ether/sco_modeling/sco_workdir/galaxy_data"
    exit 1
fi

# Prompt helper for optional interactive parameters
prompt_with_default() {
    local prompt_message=$1
    local default_value=$2
    read -p "$prompt_message [${default_value}]: " input_value
    if [ -z "$input_value" ]; then
        input_value=$default_value
    fi
    echo "$input_value"
}

# Assume the script is run from the analysis root.
# The project root is the parent directory that contains analysis/.
project_root="$(dirname "$current_dir")"

# Job logs should live in the galaxy base directory: analysis/{GALAXY}/joblogs
job_logs_dir="${current_dir}/${galaxy_name}/joblogs"

# Seed defaults for galaxy.params from existing model_files/galaxy.params if present.
default_distance="10.0"
default_vmin="-300."
default_vmax="300."
global_galaxy_params="${project_root}/model_files/galaxy.params"
if [ -f "$global_galaxy_params" ]; then
    parsed_distance=$(awk '$1=="distanceMpc" {print $2; exit}' "$global_galaxy_params")
    parsed_vmin=$(awk '$1=="vmin" {print $2; exit}' "$global_galaxy_params")
    parsed_vmax=$(awk '$1=="vmax" {print $2; exit}' "$global_galaxy_params")
    [ -n "$parsed_distance" ] && default_distance="$parsed_distance"
    [ -n "$parsed_vmin" ] && default_vmin="$parsed_vmin"
    [ -n "$parsed_vmax" ] && default_vmax="$parsed_vmax"
fi

distance_mpc=$(prompt_with_default "Enter distanceMpc for galaxy.params" "$default_distance")
vmin_value=$(prompt_with_default "Enter vmin for galaxy.params" "$default_vmin")
vmax_value=$(prompt_with_default "Enter vmax for galaxy.params" "$default_vmax")

mkdir -p "$galaxy_data_root"
mkdir -p "$galaxy_data_root/$galaxy_name"
mkdir -p "$galaxy_data_root/$galaxy_name/olm_data/"
mkdir -p "$galaxy_data_root/$galaxy_name/olm_data/muse"
mkdir -p "$galaxy_data_root/$galaxy_name/olm_data/muse/spec_files"
mkdir -p "$galaxy_data_root/$galaxy_name/olm_data/stis"
mkdir -p "$galaxy_data_root/$galaxy_name/olm_data/stis/spec_files"
mkdir -p "$job_logs_dir"

# Shared template directories under the analysis root (sco_workdir)
mkdir -p "$current_dir/muse_templates"
mkdir -p "$current_dir/stis_templates"

# Shared PSF directories under the analysis root (sco_workdir)
mkdir -p "$current_dir/muse_psf"
mkdir -p "$current_dir/stis_psf"

# Create root directory
mkdir -p "$current_dir/$galaxy_name"

# Create kinematics subdirectories
mkdir -p "$current_dir/$galaxy_name/kinematics/muse/kinematic_extraction"/{bad_spec,output_logs,output_ps,slurm_files}
mkdir -p "$current_dir/$galaxy_name/kinematics/muse/spectral_binning/bad_spec"
mkdir -p "$current_dir/$galaxy_name/kinematics/stis/kinematic_extraction"/{bad_spec,output_logs,output_ps,slurm_files}
mkdir -p "$current_dir/$galaxy_name/kinematics/stis/spectral_binning/bad_spec"

# Create modeling subdirectories
mkdir -p "$current_dir/$galaxy_name/modeling/base"
mkdir -p "$current_dir/$galaxy_name/modeling/gridrecords"
mkdir -p "$current_dir/$galaxy_name/modeling/mods/vlookdir"
mkdir -p "$current_dir/$galaxy_name/modeling/res"

# Create sb_analysis subdirectories
mkdir -p "$current_dir/$galaxy_name/sb_analysis/binning/binning.outputs"
mkdir -p "$current_dir/$galaxy_name/sb_analysis/deprojection/deprojection.outputs"

# Create helper hidden input files used by wrapper scripts.
# We place them in both galaxy-level kinematics and per-spectrograph
# kinematic_extraction directories to support existing wrapper behavior.
create_wrapper_input_files() {
    local target_dir=$1
    cat > "$target_dir/.pallmc_in" << 'EOF'
pallmc_inlist
/VCPS
EOF

    cat > "$target_dir/.pfitlov_in" << 'EOF'
ll
/VCPS
EOF

    cat > "$target_dir/.pfitlove_in" << 'EOF'
pfitlove_inlist
/VCPS
EOF
}

create_wrapper_input_files "$current_dir/$galaxy_name/kinematics"
create_wrapper_input_files "$current_dir/$galaxy_name/kinematics/muse/kinematic_extraction"
create_wrapper_input_files "$current_dir/$galaxy_name/kinematics/stis/kinematic_extraction"

# Initialize per-galaxy modeling parameters used by sbanalysis/finalizeextraction.
cat > "$current_dir/$galaxy_name/sb_analysis/binning/galaxy.params" << EOF
${galaxy_name}
distanceMpc  ${distance_mpc}
angleRmax     90
vmin         ${vmin_value}
vmax          ${vmax_value}
slope_0       -1.0
MtoL          10.
islitsize     0  (0=nothing; 1=0.1"x0.2"; 2=0.1"x0.1" (HST))
EOF

# Initialize iteration and seeing files consumed by modeling/finalize scripts.
cat > "$current_dir/$galaxy_name/sb_analysis/binning/iter.params" << 'EOF'
Niter         15
apfac          0.7
apfacmu        0.
ifit           2
alphainc       1.1
alphastop      1e5
fracrv         0.02
EOF

cat > "$current_dir/$galaxy_name/sb_analysis/binning/see_muse.dat" << 'EOF'
Bin Seeing
1    0.42
2    0.09
EOF

cat > "$current_dir/$galaxy_name/sb_analysis/binning/see_stis.dat" << 'EOF'
Bin Seeing
1    0.42
2    0.09
EOF

# Keep a generic see.dat for convenience; pipelines may overwrite this by instrument.
cp "$current_dir/$galaxy_name/sb_analysis/binning/see_muse.dat" \
    "$current_dir/$galaxy_name/sb_analysis/binning/see.dat"

# finalizeextraction expects these defaults in shared PSF folders.
cp "$current_dir/$galaxy_name/sb_analysis/binning/see_muse.dat" \
    "$current_dir/muse_psf/see_both.dat"
cp "$current_dir/$galaxy_name/sb_analysis/binning/see_stis.dat" \
    "$current_dir/stis_psf/see_stis.dat"

echo "Directory structure for '$galaxy_name' created successfully!"

# Update or create the SCO framework configuration file
config_file="${framework_root}/.sco_config"
cat > "$config_file" << EOF
# SCO Framework Configuration
# Auto-generated by initialize_directory_structure

# Root analysis directory (where galaxy workspaces are created)
export SCO_ANALYSIS_ROOT="${current_dir}"

# Project root (contains analysis, model_files, templates, psf directories)
export SCO_PROJECT_ROOT="${project_root}"

# External galaxy data directory (optional, for spectral data lookups)
# Update this if you have external galaxy data stored elsewhere
export SCO_GALAXY_DATA_ROOT="${galaxy_data_root}"

# Job output logs directory for SLURM submissions
export JOB_OUTPUT_LOGS="${job_logs_dir}"

# Framework bin directory (automatically set)
export SCO_FRAMEWORK_BIN="${script_dir}"
export SCO_FRAMEWORK_ROOT="${framework_root}"
EOF

echo "SCO Framework configuration created/updated at: $config_file"
echo "Analysis root directory set to: $current_dir"
echo "Project root set to: $project_root"
echo "Galaxy data root set to: $galaxy_data_root"
echo "Job logs directory set to: $job_logs_dir"
echo "Initialized galaxy params at: $current_dir/$galaxy_name/sb_analysis/binning/galaxy.params"
echo "Initialized iter params at: $current_dir/$galaxy_name/sb_analysis/binning/iter.params"
echo "Initialized seeing files at: $current_dir/$galaxy_name/sb_analysis/binning/see_muse.dat and see_stis.dat"
echo "Initialized PSF defaults at: $current_dir/muse_psf/see_both.dat and $current_dir/stis_psf/see_stis.dat"
echo "IMPORTANT: update PSF FWHM values in see_muse.dat/see_stis.dat (and related PSF files) before running modeling."

bashrc_file="$HOME/.bashrc"

if [ -f "$bashrc_file" ]; then
    backup_file="$HOME/.bashrc.sco_init.bak.$(date +%Y%m%d%H%M%S)"
    cp "$bashrc_file" "$backup_file"

    # Portable in-place sed helper for Linux/macOS.
    sedi() {
        if sed --version >/dev/null 2>&1; then
            sed -i "$@"
        else
            sed -i '' "$@"
        fi
    }

    upsert_alias() {
        local alias_name="$1"
        local target_path="$2"
        local alias_line
        local escaped_line

        alias_line="alias ${alias_name}='cd \"${target_path}\"'"
        escaped_line=${alias_line//&/\\&}

        if grep -qE "^alias ${alias_name}=" "$bashrc_file"; then
            sedi "s|^alias ${alias_name}=.*$|${escaped_line}|" "$bashrc_file"
        else
            printf "%s\n" "$alias_line" >> "$bashrc_file"
        fi
    }

    upsert_alias "cdw" "$project_root"
    upsert_alias "modprogs" "$framework_root/modprogs"
    upsert_alias "bin" "$framework_root/bin"
    upsert_alias "galdata" "$galaxy_data_root/$galaxy_name"
    upsert_alias "joblogs" "$job_logs_dir"
    upsert_alias "kinm" "$current_dir/$galaxy_name/kinematics/muse/kinematic_extraction"
    upsert_alias "kins" "$current_dir/$galaxy_name/kinematics/stis/kinematic_extraction"
    upsert_alias "musedata" "$galaxy_data_root/$galaxy_name/olm_data/muse"
    upsert_alias "stisdata" "$galaxy_data_root/$galaxy_name/olm_data/stis"
    upsert_alias "sb" "$current_dir/$galaxy_name/sb_analysis"
    upsert_alias "mods" "$current_dir/$galaxy_name/modeling"
    upsert_alias "kindir" "$current_dir/$galaxy_name/kinematics"

    echo "Updated SCO aliases in ~/.bashrc for galaxy: $galaxy_name"
    echo "Backup saved to: $backup_file"
    echo "Run 'source ~/.bashrc' to load aliases into your current shell."
else
    echo "Warning: ~/.bashrc not found; skipped alias updates."
fi
