#!/bin/bash
set +o noclobber
shopt -s nullglob

# Source the SCO environment configuration
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${script_dir}/sco_env.sh"

# Get the current directory where the script is being run
current_dir=$(pwd)
rootdir="${SCO_PROJECT_ROOT}"

if [ -z "$rootdir" ] || [ ! -d "$rootdir" ]; then
    echo "Error: SCO_PROJECT_ROOT is not set or does not exist: '$rootdir'"
    echo "Re-run initialize_directory_structure or update .sco_config."
    exit 1
fi

# Create a directory to store problematic bins
bad_spec_dir="${current_dir}/bad_spec"
mkdir -p $bad_spec_dir

# Create a directory to store output .ps files
output_ps_dir="${current_dir}/output_ps"
mkdir -p $output_ps_dir

# Create a directory to store the output logs
logs_dir="${current_dir}/output_logs"
mkdir -p $logs_dir

# Create a directory to store the slurm files
slurm_dir="${current_dir}/slurm_files"
mkdir -p $slurm_dir

# Config file to store last inputs
config_file="${current_dir}/.lastinput"

# Prompt Function for user inputs
prompt_with_default() {
    local prompt_message=$1
    local default_value=$2
    read -p "$prompt_message [${default_value}]: " input_value
    if [ -z "$input_value" ]; then
        input_value=$default_value
    fi
    echo $input_value
}

# Load previous script inputs if the config file exists
if [[ -f $config_file ]]; then
    source $config_file
else
    last_galaxy=""
    last_spectrograph=""
    last_line_choice=""
    last_redshift=""
    last_smoothing=""
fi

# Prompt for user inputs
galaxy=$(prompt_with_default "Enter the galaxy directory" $last_galaxy)
if [ -z "$galaxy" ]; then
    echo "Galaxy must be provided."
    exit 1
fi

spectrograph=$(prompt_with_default "Enter the spectrograph (muse/stis)" $last_spectrograph)
case $spectrograph in
    muse)
        wavelengthmin=4750
        step=1.25
        ;;
    stis)
        wavelengthmin=8275.0
        step=0.55859375
        ;;
    *)
        echo "Invalid spectrograph. Please enter 'muse' or 'stis'."
        exit 1
        ;;
esac

line_choice=$(prompt_with_default "Choose the spectral line region (1: CaII Triplet; 2: Mgb Line)" $last_line_choice)
case $line_choice in
    1)
        wavemin=8300.0 #8275.0
        wavemax=8900.0 # 8847.0
        ;;
    2)
        wavemin=4900.0
        wavemax=5500.0
        ;;
    *)
        echo "Invalid choice. Enter either '1' or '2'."
        exit 1
        ;;
esac

redshift=$(prompt_with_default "Enter the redshift" $last_redshift)
redshift_number=$(echo $redshift | sed 's/^z=//')

smoothing=$(prompt_with_default "Enter the spectral fit smoothing" $last_smoothing)

# Store current inputs to config file
cat <<EOL > $config_file
last_galaxy=$galaxy
last_spectrograph=$spectrograph
last_line_choice=$line_choice
last_redshift=$redshift
last_smoothing=$smoothing
EOL

# Function to exit the script
exit_function() {
    echo "Kinematic extraction for ${galaxy} using ${spectrograph} is almost complete! Continue by running the finalizextraction script after the MCMC is finished."
    exit 0
}

# Function to check for individual routine output files and allow user to skip to the next routine
check_and_prompt() {
    local pattern=$1
    local prompt_message_existing_files=$2
    local prompt_message_no_files=$3
    local files=( $pattern )

    if [ ${#files[@]} -eq 0 ]; then
        read -p "$prompt_message_no_files (Y/N): " user_input
        if [[ "${user_input:-Y}" =~ ^[Yy]$ ]]; then
            return 1  # Indicate that the user chose to run the current function
        else
            exit_function  # Indicate that the user chose not to run the function when no previous files exist
        fi
    else
        read -p "$prompt_message_existing_files (Y/N): " user_input
        if [[ "${user_input:-N}" =~ ^[Yy]$ ]]; then
            return 0  # Indicate that the user chose to skip
        fi
        return 1  # Indicate that the user chose to run the current function
    fi
}

# Get rid of known bad spec files
if [ -f "${current_dir}/known_bad_spectra" ]; then 
    echo "Removing known bad spectra..."
    "${current_dir}/known_bad_spectra"
fi

########################################
#             FIT CONTINUUM            #
########################################

continuum_fit() {

    # Check for old outputs
    check_and_prompt "b*.norm" "The continuum normalization has been previously completed. Do you want to skip it?" \
                               "Do you want to run the continuum normalization?"
    if [ $? -eq 0 ]; then
        echo "Skipping to LOSVD extraction..."
        return
    fi

    # Check for the required inputs:
    files=$(ls b*.spec 2> /dev/null)

    if [ -z "$files" ]; then
        echo "Missing inputs for continua fits. Exiting..."
        exit 1
    fi

    # Clean bad_spec and get rid of any leftover temporary outfile lists
    rm -f *.norm *.output vels.dat regions.dat l*
    # replace vels.dat and regions.dat
    turbodir="${SCO_GALAXY_DATA_ROOT}"

    cp ${turbodir}/${galaxy}/olm_data/${spectrograph}/spec_table.dat ${current_dir}/vels.dat
    cp ${turbodir}/${galaxy}/olm_data/${spectrograph}/regions.dat ${current_dir}/

    # Prompt user to ask if they want to restrict wavelength range for continuum fit
    ncol=$(awk 'END{print NR}' b*.spec | head -1) # use awk to handle floats
    wavelengthmax=$(awk -v min="$wavelengthmin" -v step="$step" -v n="$ncol" 'BEGIN{print min + step * (n-1)}') 

    read -p "Do you want to restrict the wavelength range for continuum fit? (Y/N): " restrict_range

    if [[ "${restrict_range:-N}" =~ ^[Yy]$ ]]; then
        if [ "$spectrograph" == "muse" ]; then
            ilo=2900
            ihi=3210
        elif [ "$spectrograph" == "stis" ]; then
            ilo=320
            ihi=800
        else
            echo "What indices do you want to use for the continuum fit? (min: 1, max: $ncol)"
            read -p "Enter min index: " ilo
            read -p "Enter max index: " ihi
            if ! [[ "$ilo" =~ ^[0-9]+$ ]] || ! [[ "$ihi" =~ ^[0-9]+$ ]] || [ "$ilo" -lt 1 ] || [ "$ihi" -gt "$ncol" ] || [ "$ilo" -ge "$ihi" ]; then
                echo "Invalid indices. Please enter integers between 1 and $ncol, with min index less than max index."
                exit 1
            fi
        fi
        echo "$ilo $ihi" > limits.imfit
        echo "Continuum fit will be restricted to indices: $ilo to $ihi"
    else
        rm -f limits.imfit 2>/dev/null
    fi

    # Create a list to run rimfit on all .dat files
    for file in b*.spec; do
        echo "rimfit $(basename "${file}") $(basename "${file}" .spec).norm $spectrograph"
    done > ${current_dir}/l2

    # Make the list executable and run it
    chmod +x ${current_dir}/l2
    ${current_dir}/l2 >> rimfit.output

    # Check for errors in rimfit outputs and move problematic bins
    grep "Too Many Zeros" rimfit.output >> l11
    grep -o "b.*sp.spec" l11 | sed 's/\.[^.]*$//' >> l12
    awk '{if (system("ls " $1"* > /dev/null 2>&1") == 0) print "mv", $1"*", "./bad_spec/"}' l12 > l13
    chmod +x l13
    ${current_dir}/l13

    # Check for bins with failed fits (.norm files that have $2 being all zero)
    for file in b*.norm; do
        all_zeros=true

        awk '{if ($2 != 0) exit 1}' "${file}"
        if [ $? -ne 0 ]; then
            all_zeros=false
        fi
        if [ "$all_zeros" = true ]; then
            base_name="${file%.*}"
            for related_file in ${base_name}*; do
                if [ -f "$related_file" ]; then
                    mv "$related_file" ${current_dir}/bad_spec/
                fi
            done
        fi
    done

    # Check for bins with failed fits (no associated .ps files)
    for binfile in b??????sp*; do
        prefix="${binfile%%sp*}"
        if ! ls "${prefix}"*sp_rimfit.ps > /dev/null 2>&1; then
            echo "${prefix}" >> l31
        fi
    done

    # Make sure l31 file is not empty and execute it.
    if [ -s l31 ]; then
        sort l31 | uniq > l32
        awk '{if (system("ls " $1"* > /dev/null 2>&1") == 0) print "mv", $1"*", "./bad_spec/"}' l32 > l33
        chmod +x l33
        ${current_dir}/l33
    fi

    rm -f l1 l2 l11 l12 l13 l31 l32 l33 *.def
    if ls *rimfit.ps 1> /dev/null 2>&1; then
        mv *rimfit.ps ${current_dir}/output_ps
    fi

}
continuum_fit

########################################
#     FIT CAII AND EXTRACT LOSVD       #
########################################

extract_LOSVD() {
    # Check for old outputs
    check_and_prompt "b*.fit" "The LOVSD extraction has been previously completed. Do you want to skip it?" \
                              "Do you want to fit CaII triplets and extract the LOSVDs?"
    if [ $? -eq 0 ]; then
        echo "Skipping to the LOSVD error estimation..."
        return
    fi

    # Check for the required inputs:
    files=$(ls b*.norm 2> /dev/null)

    if [ -z "$files" ]; then
        echo "Missing inputs for CaII fit and LOSVD extraction."
        exit 1
    fi

    # Copy stellar template files to current directory

    cp ${rootdir}/${spectrograph}_templates/*.txt "${current_dir}/"
    cp ${rootdir}/${spectrograph}_templates/Tlist "${current_dir}/"

    # Create a list to run rfitlov on all .norm files
    for file in b*.norm; do
        echo "rfitlov $(basename "${file}" .norm) $wavemin $wavemax $redshift_number $spectrograph $smoothing"
    done > ${current_dir}/l3

    # Make the list executable and run it
    chmod +x ${current_dir}/l3
    ${current_dir}/l3 >> rfitlov.output

    if ls *fitlov.ps 1> /dev/null 2>&1; then
        mv *fitlov.ps ${current_dir}/output_ps
    fi

    # Make LOSVD plots

    cp -f "$(sco_get_galaxy_path "$galaxy")/kinematics/.pfitlov_in" ${current_dir}
    ls b*sp.fit > ll
    ls b*sp.fit > pfitlov_inlist

    pfitlov < .pfitlov_in  >> out

    if ls pgplot.ps 1> /dev/null 2>&1; then
        mv ${current_dir}/pgplot.ps ${current_dir}/output_ps/${galaxy}_losvds.ps
    fi

    # Remove temporary lists and files
    cp -f pfitlov.out ${current_dir}/pfitlov.output
    rm -f *.def out ascii.out rms.out fitlov.out pfitlov.out pgplot.ps fit.ps *.temp l3 ll .pfitlov_in
}
extract_LOSVD


########################################
#     LOSVD ERROR DETERMINATION        #
########################################

run_MCMC() {
    # Check for old outputs
    check_and_prompt "b*.sim" "The LOVSD error estimation has been previously completed. Do you want to skip it?" \
                              "Do you want to estimate the error on the LOSVDs with MCMC?"
    if [ $? -eq 0 ]; then
        echo "Skipping to the LOSVD error estimation..."
        return
    fi

    # Check for the required inputs:
    files=$(ls b*.rms 2> /dev/null)

    if [ -z "$files" ]; then
        echo "Missing inputs for LOSVD error estimation."
        exit 1
    fi

    # Create a list to run rmcfit on extracted LOSVDs
    for file in b*.rms; do
        rms=$(awk '{printf "%.5f", $1}' $file)
        echo "rmcfit $(basename "${file}" .rms) $wavemin $wavemax $redshift_number $spectrograph $smoothing $rms"
    done > ${current_dir}/losvd_mcmc

    # Make the list executable and run it
    chmod +x ${current_dir}/losvd_mcmc

    # create slurm jobs for the mcmc with jobsplitter
    rm -rf ${current_dir}/*.slurm ${current_dir}/*.run jobsplitter.output
    cp ${SCO_FRAMEWORK_BIN}/templates.mcmc.slurm ${current_dir}/template.slurm

    n_lines=$(wc -l < ${current_dir}/losvd_mcmc)

    jobsplitter losvd_mcmc 01:00:00

    rm -f *.def out ascii.out rms.out fitlov.out fitlov.temp pgplot.ps fit.ps *.temp losvd_mcmc template.slurm

}
run_MCMC

exit_function

