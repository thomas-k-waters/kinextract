#!/bin/bash
set +o noclobber

if [ $# -ne 2 ]; then
    echo "Usage: $0 q_obs inc_deg"
    exit 1
fi

q_obs="$1"
inc_deg="$2"
q_true=$(awk -v q="$q_obs" -v deg="$inc_deg" '
    function abs(x) { return x<0 ? -x : x }
    BEGIN {
        # Basic validation of inputs
        if (q <= 0 || q > 1) {
            print "rgdenconv: q_obs must be in (0,1] but got " q > "/dev/stderr";
            exit 2
        }
        if (deg <= 0 || deg > 90) {
            print "rgdenconv: inc_deg must be in (0,90] but got " deg > "/dev/stderr";
            exit 2
        }

        rad = deg * (atan2(0, -1) / 180)
        c = cos(rad)
        s = sin(rad)
        num = q*q - c*c
        denom = s*s
        if (abs(denom) < 1e-12) {
            print "rgdenconv: inclination too close to 0 deg (face-on), denominator is zero." > "/dev/stderr";
            exit 1
        }
        if (num < 0) {
            # Physically impossible: require deg >= acos(q)
            imin = acos(q) * 180 / (atan2(0,-1))
            printf("rgdenconv: invalid q_obs=%.4f and inc=%.4f deg. Minimum allowed inc is %.3f deg.\n", q, deg, imin) > "/dev/stderr";
            exit 1
        }
        print sqrt(num/denom)
    }
') || {
    # awk failed; propagate a clear error and stop
    echo "rgdenconv: failed to compute intrinsic axis ratio (q_true) from q_obs=${q_obs}, inc=${inc_deg}." 1>&2
    exit 1
}

gdenconv << eof >> tmp.out
npdyn.out
${q_obs} ${q_true}
eof
