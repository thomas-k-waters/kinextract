#!/bin/bash
set +o noclobber  # Allow overwriting files

# Source the SCO environment configuration
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${script_dir}/sco_env.sh"

ddir=$(pwd)

# Determine the galaxy name from the directory structure
# runalls should be called from the modeling/{galaxy_name}/ directory
# We need to find which galaxy directory we're working with
# by traversing up the directory tree
function get_galaxy_name() {
    local current="$1"
    # Keep going up until we find a directory with the expected structure
    while [ "$current" != "/" ]; do
        if [ -d "$current/kinematics" ] && [ -d "$current/sb_analysis" ] && [ -d "$current/modeling" ]; then
            echo "$(basename "$current")"
            return 0
        fi
        current="$(dirname "$current")"
    done
    return 1
}

galaxy_name=$(get_galaxy_name "$ddir")
if [ -z "$galaxy_name" ]; then
    echo "Error: Could not determine galaxy name from directory structure" >&2
    echo "runalls should be run from the modeling/{galaxy_name}/ directory" >&2
    exit 2
fi

# Export environment variables for child processes (like variable_ml.py)
export SCO_GALAXY_NAME="$galaxy_name"

if [ "$#" -ne 7 ]; then
    echo "Usage: $(basename "$0") M/L Upsilon_ratio M_bh v_c r_c apparent_q inclination" 1>&2
    exit 2
fi

ml="$1"
xi="$2"
mbh="$3"
vc="$4"
rc="$5"
apparent_q="$6"
inclination="$7"


libn=m${ml}b${mbh}v${vc}r${rc}i${inclination}x${xi}
base=${ddir}/base
res=${ddir}/res
flatness=1

cd mods

rm -rf $libn
mkdir $libn
cd $libn
cp -r $base/* .

# Expect npdyn.out to be present (prepared externally) before proceeding
if [ ! -s npdyn.out ]; then
    echo "runalls: expected npdyn.out not found; please generate/copy it before running (inclination-dependent SB)." 1>&2
    exit 1
fi

rgdenconv "$apparent_q" "$inclination"
# gdenconv appends to tmp.out; bail if it failed to produce gden.out
if [ ! -s gden.out ]; then
    echo "runalls: gden.out not produced by rgdenconv; stopping." 1>&2
    exit 1
fi
cp gden.out gden.use

gden << eof
gden.use
0.005
$inclination
$mbh
$ml $flatness
3
$vc $rc
eof

if [ "$(echo "$xi < 1.0" | bc -l)" -eq 1 ]; then
    [ -f ratML.dat ] && mv ratML.dat ratML_original.dat
    python "${SCO_FRAMEWORK_BIN}/variable_ml.py" "$ml" "$xi"
    cp ratML.dat "ratML_var_m${ml}b${mbh}v${vc}r${rc}i${inclination}x${xi}.dat"
fi

library.x
plot.libsos.x
mv pgplot.ps libsos.ps
sos2vor.x > /dev/null
cp "${SCO_FRAMEWORK_BIN}/varea" .
chmod +x varea.script
varea.script > /dev/null
vor2vphase.x > /dev/null
cp phase.vor phase.out
cp velbin.sav velbin.dat
seecor.x > /dev/null

head -1 velbin.sav > velbin.dat
model.x << eof
0
1.
0
1
1.e-10
1
eof
seecor2.x
rm -f *.vor.* *.nuclei

rmodel "${libn}" "${res}"

vlook.x << eof
/cps
eof
paste gherm.out ghermd.out > gherm.${libn}
cp gherm.${libn} "${res}/gherm.${libn}"
chmod a+r "${res}"/*.${libn}

rm -f tmp.out

