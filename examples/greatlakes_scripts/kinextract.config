###############################################################################
# kinextract.config
#
# Spectrum file is passed on the command line:
#
#   python -m kinextract /path/to/bin0105sp.spec /path/to/kinextract.config
#
# Values below are kept consistent with examples/notebooks/03_real_data_muse.ipynb
# in the kinextract package (lib/kinextract) wherever that notebook sets a field
# explicitly; sections/fields the notebook doesn't touch (ALS optimization,
# absorption cleaning, masking) reflect additional production tuning beyond
# what the notebook demonstrates.
###############################################################################


[paths]

template_list_file = "/scratch/kayhan_root/kayhan0/waterstk/orbit_library_modeling/analysis/muse_templates/Tlist"
template_dir = "/scratch/kayhan_root/kayhan0/waterstk/orbit_library_modeling/analysis/muse_templates/"
regions_bad_path = ""
outdir = "/scratch/kayhan_root/kayhan0/waterstk/orbit_library_modeling/analysis/N5102/kinematics/muse/kinematic_extraction/"
galaxy_params_path = "/scratch/kayhan_root/kayhan0/waterstk/orbit_library_modeling/analysis/N5102/sb_analysis/binning/"
use_galaxy_params_velocity_bounds = true

[wavelength]

wavemin_full = 4750.0
step = 1.25
wavefitmin = 8400.0
wavefitmax = 8750.0
zgal = 0.00157811
norm_wave_frame = "auto"
spec_col3_is_variance = false
# Set false to ignore per-pixel input errors and use the median error uniformly
# (equal pixel weighting).  Error column is still read; only fit weights change.
use_spectrum_errors = false

# MUSE per-pixel flux errors are not very reliable (see the MUSE notebook);
# if set, kinematicextraction computes a uniform gal_errors = flux / snr_override
# override for every spectrum (matching the notebook) instead of using the
# file's error column. Leave unset/commented to use file-provided errors
# (still gated by use_spectrum_errors above).
snr_override = 50.0

[kinematics]

sigl = 100.0
smoothing = 100.0

# Per-spectrum automatic smoothing parameter selection.
# Search xlam_auto_grid ascending; stop at the first xlam where LOSVD roughness
# (max|D²b|/peak) ≤ xlam_smooth_threshold.  cfg.xlam is updated to the chosen
# value; bootstrap refits use that fixed value (xlam_auto=false in frozen cfg).
xlam_auto = true
# "roughness" matches the MUSE notebook (picks the smallest xlam whose LOSVD
# roughness falls at or below xlam_smooth_threshold); the package default is
# "chi2" (picks the largest xlam within a chi2 tolerance of the grid minimum,
# scale-invariant across sigma) -- switch to "chi2" if you stop needing to
# hand-tune xlam_smooth_threshold per galaxy.
xlam_criterion = "roughness"
xlam_auto_grid = [1.0, 10.0, 100.0, 1000.0, 10000.0, 50000.0, 100000.0]
# Smooth Gaussian inherent roughness: σ=44 km/s → 0.16, σ=100 km/s → 0.03.
# 0.25 accepts narrow LOSVDs while rejecting noise spikes.
xlam_smooth_threshold = 0.25
# Unimodality constraint: reject xlam values that produce more than max_peaks
# local maxima in the LOSVD (only peaks above min_prominence * global_peak count).
# Catches double-peaked LOSVDs in inner bins that pass the roughness test.
xlam_max_peaks = 1
xlam_peak_min_prominence = 0.1
# Reduced iteration budget for search fits (shape reliable before full convergence).
xlam_auto_maxiter = 2000

[continuum]

fit_als_continuum = false

[als]

als_lam = 1.0
als_p = 0.5
als_niter = 25
als_outer_iter = 15
als_outer_tol = 1.0e-6
als_eps = 1.0e-6
als_clip = [0.0, "inf"]

[als_optimization]

als_optimize = true
# Run the full lambda/p grid search once (at init) and reuse the result
# for all outer iterations.  Eliminates O(als_outer_iter) redundant searches.
als_optimize_init_only = true
als_lam_grid = [
    1.0e0,
    1.0e1,
    1.0e2,
    1.0e3,
    1.0e4,
]
als_p_grid = [
    0.3,
    0.5,
    0.7,
]
als_lam_grid_fine_n = 20
als_p_grid_fine_n = 5
als_lambda_floor = 1.0
als_opt_verbose = false
als_template_selection = "nnls"
als_bic_dof_penalty = 0.5
als_use_bic = true
als_chisq_floor = 0.8
als_hutchinson_probes = 25

[als_masks]

als_mask_ca = true
als_ca_centers = [
    8498.02,
    8542.09,
    8662.14,
]
als_ca_half_widths = [
    6.0,
    6.0,
    6.0,
]
als_ca_frame = "rest"
als_mask_velocity_pad_kms = 250.0
als_mask_center_shift_A = 0.0

# Auto-refine mask center shift using the Ca II triplet as a reference.
# Corrects for slight zgal errors so mask windows track the actual features.
# Masking-only: no effect on velocity/LOSVD measurements.
als_auto_caii_shift = true
als_auto_caii_search_hw_A = 12.0

als_use_default_caii_region_lines = false
als_default_abs_half_width = 5.0
als_default_pas_half_width = 3.0
als_default_em_half_width = 1.75
als_extra_mask_frame = "rest"
als_extra_mask_windows = []
als_extra_mask_line_frame = "rest"
als_extra_mask_lines = []

[als_auto_masking]

# S/N-gated auto-detection of absorption lines for ALS continuum masking only.
# Disabled: raw S/N in a fixed context window produces false positives near the
# Ca II triplet.  als_abs_clean below is the data-driven replacement.
als_auto_mask_abs_lines = false
als_auto_mask_paschen = false
als_auto_mask_snr_threshold = 5.0
als_auto_mask_half_width_A = 5.0
als_auto_mask_snr_context_A = 25.0

[als_absorption_cleaning]

# Primary mechanism for masking absorption features from the ALS continuum fit.
# Fits the continuum, rejects pixels below -sigma * robust_sigma(residuals),
# grows the mask by grow_A angstroms, and refits.  No line list required —
# detects any feature (including unknown lines) that dips below the continuum.
als_abs_clean = true
als_abs_clean_iter = 25
als_abs_clean_sigma = 5.0
als_abs_clean_grow_A = 4.0
als_abs_clean_two_sided = false
als_abs_clean_minpix = 50
# Run abs_clean once at init and reuse the resulting mask for all outer
# iterations.  Combined with als_optimize_init_only=true, outer iterations
# cost only a single fixed-lambda ALS refit.
als_abs_clean_init_only = true

[spectral_masking]

# Emission lines are absent from stellar templates; pre-mask them so they
# cannot bias the LOSVD fit even if too weak to be sigma-clipped.
# An S/N check on the local continuum ensures lines not present in the
# spectrum are skipped (set snr_threshold = 0 to mask unconditionally).
mask_emission_lines_in_fit = true
mask_paschen_lines_in_fit = false
mask_emission_line_half_width_A = 5.0
mask_emission_line_snr_threshold = 5.0
mask_emission_line_snr_context_A = 25.0

# Grow the combined emission mask by this many Å after detection.
# Covers line wings just below the SNR threshold and merges closely-spaced
# emission lines into a single contiguous masked region.
mask_emission_grow_A = 2.0

# Foreground absorption NOT in the templates (e.g. ISM Ca II H&K, telluric).
# Protected from sigma-clipping.  Leave empty unless you have a specific need.
# Format: [[center_A, half_width_A], ...]
extra_absorption_lines = []

[losvd]

icoff = 1
coff = 0.0
coff2 = 0.0
fortran_nlosvd_full_x = true
fortran_template_mixture = true
fortran_mask_template_outside = true
fit_global_amp = false


[optimizer]

map_maxiter = 10000
map_maxfun = 500000
# 1e-10/1e-8 are the current package defaults (see FitConfig docstring):
# validated to give a large (~20x) speedup over the tighter values this file
# used to carry, with no measurable change in the recovered LOSVD shape.
# The old, much tighter values (1e-12/1e-10) also masked a real bug where an
# under-converged MAP fit could make the Laplace error covariance indefinite
# (see LOSVDErrorEstimator.laplace_covariance's convergence warning) --
# don't tighten these back without re-validating.
map_ftol = 1.0e-10
map_gtol = 1.0e-8
map_maxls = 50
use_scaled_optimizer = true
print_every = 100000

[cleaning]

clean = true
clean_sigma = 3.0
clean_maxiter = 10
clean_minpix = 50
clean_protect_ca_triplet = true
clean_ca_centers = [
    8498.02,
    8542.09,
    8662.14,
]
clean_ca_half_width = 6.0
clean_bloom_pixels = 3
clean_protect_absorption_only = false
clean_protect_ca_frame = "rest"
clean_protect_windows_frame = "rest"
clean_protect_windows = []

[errors]

run_errors_default = true
run_bootstrap_default = true
n_bootstrap = 200
n_jobs = -1

[jax]
use_jax_objective = true
jax_enable_x64 = true
