#!/bin/bash
set -euo pipefail

# Wrapper: run the model grid generator (interactive) and then trim the resulting run list

# Choose Python executable
if command -v python >/dev/null 2>&1; then
  PY=python
elif command -v python3 >/dev/null 2>&1; then
  PY=python3
else
  echo "Error: python executable not found in PATH" >&2
  exit 1
fi

# Path to the modelgrid script (override via env MODELGRID_SCRIPT)
# Default follows your previous example; change if you want to run a different generator.
MODELGRID_SCRIPT=${MODELGRID_SCRIPT:-"$HOME/sco.modeling.build/bin/modelgrid.py"}

# Run the Python generator interactively
"$PY" "$MODELGRID_SCRIPT"

# The Python script writes defaults here; read output_file from it
DEFAULTS_FILE=.modelgridnodmincdefaults.json
if [ ! -f "$DEFAULTS_FILE" ]; then
  echo "Error: defaults file '$DEFAULTS_FILE' not found after running modelgrid." >&2
  exit 1
fi

# Extract output_file using Python to avoid depending on jq
OUTPUT_FILE=$("$PY" - <<'PY'
import json, sys
with open('.modelgridnodmincdefaults.json', 'r') as f:
    data = json.load(f)
print(str(data.get('output_file', '')).strip())
PY
)

if [ -z "$OUTPUT_FILE" ]; then
  echo "Error: 'output_file' not found in $DEFAULTS_FILE." >&2
  exit 1
fi

if [ ! -f "$OUTPUT_FILE" ]; then
  echo "Error: output file '$OUTPUT_FILE' does not exist. Did the Python script save it?" >&2
  exit 1
fi

# Snapshot the inputs used for this grid
OUTPUT_DEFAULTS_COPY="${OUTPUT_FILE}.defaults.json"
cp "$DEFAULTS_FILE" "./gridrecords/$OUTPUT_DEFAULTS_COPY"
echo "Saved defaults snapshot to ./gridrecords/${OUTPUT_DEFAULTS_COPY}"

# Decide whether to run trimlist: if the user saved models (runalls), skip trimming
FIRST_CMD=$(grep -m1 -o '^[^[:space:]]*' "$OUTPUT_FILE" || true)
if [ "$FIRST_CMD" = "runalls" ]; then
  echo "Detected saved models (runalls); skipping trimlist."
  final_len=$(wc -l < "${OUTPUT_FILE}")
  echo "Saved ${OUTPUT_FILE} file with ${final_len} entries."
else
  SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
  "$SCRIPT_DIR/trimlist" "$OUTPUT_FILE"
fi
