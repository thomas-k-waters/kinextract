#!/bin/bash
set +o noclobber

# Source the SCO environment configuration
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${script_dir}/sco_env.sh"

# Check arguments
if [ "$#" -ne 2 ]; then
    echo "Usage: $0 <input_file> <time_limit>"
    echo "Example: $0 inputlist '12:00:00'"
    exit 1
fi

COMMANDS_FILE="$1"
TIME_LIMIT="$2"
BASE_NAME=$(basename "$COMMANDS_FILE" .run)
TEMPLATE_SOURCE="${SCO_FRAMEWORK_BIN}/templates.slurm"

# Copy template to current directory
if [ ! -f "$TEMPLATE_SOURCE" ]; then
    echo "Error: Template file not found at $TEMPLATE_SOURCE"
    exit 1
fi
cp "$TEMPLATE_SOURCE" ./template.slurm

# Check if input file exists
if [ ! -f "$COMMANDS_FILE" ]; then
    echo "Error: $COMMANDS_FILE not found"
    exit 1
fi

# Count total commands
total_commands=$(wc -l < "$COMMANDS_FILE")

# Default: 1 commands file
commands_file_count=1

# If total_commands > 4999, split the commands file into numeric-suffixed chunks
if [ "$total_commands" -gt 4999 ]; then
    echo "Total commands (${total_commands}) exceed 4999. Splitting into chunks of 4999..."
    split_prefix="${BASE_NAME}_"
    # Create files like BASE_NAME_00, BASE_NAME_01, ...
    split -l 4999 -d "$COMMANDS_FILE" "$split_prefix"
    # Count only files that match numeric suffixes to avoid false positives (e.g., *_joblist)
    commands_file_count=$(ls -1 "${split_prefix}"[0-9][0-9]* 2>/dev/null | grep -v -E '(\.slurm|_joblist)' | wc -l | tr -d ' ')
    echo "Created ${commands_file_count} job array files:"
    ls -1 "${BASE_NAME}_"[0-9][0-9]* | grep -v -E '(\.slurm|_joblist)'
    echo ""
fi

# Ask the user if they want to submit the jobs now, save response as a variable ('Y' or 'N')
read -p "Do you want to submit the jobs now? (Y/N) " submit_now
if [[ "$submit_now" != "Y" && "$submit_now" != "y" && "$submit_now" != "N" && "$submit_now" != "n" ]]; then
    echo "Invalid input. Please enter Y or N."
    exit 1
fi
if [[ "$submit_now" =~ ^[Yy] ]]; then
    submit_now="Y"
else
    submit_now="N"
fi

# List the commands files created and ask the user which to use (if we split)
if [[ "$submit_now" =~ ^[Yy] ]]; then
    if [ "$commands_file_count" -gt 1 ]; then
        echo "Only one job array can be submitted at this time."
        read -p "Enter the job array file to use for this job submission: " selected_commands_file
        if [ ! -f "$selected_commands_file" ]; then
            echo "Error: Selected job array file not found: $selected_commands_file"
            exit 1
        fi
        COMMANDS_FILE="$selected_commands_file"
        total_commands=$(wc -l < "$COMMANDS_FILE")
    fi
fi

# Use the selected commands file name as the base for joblist and slurm files
commands_basename=$(basename "$COMMANDS_FILE" .run)

# Keep the provided commands file, and also write a canonical joblist name
array_commands_file="${commands_basename}_joblist"
cp "$COMMANDS_FILE" "$array_commands_file"

# Create array-enabled slurm template
array_slurm_file="${commands_basename}.slurm"
sed "s|{BATCH_NUM}|${commands_basename}|g; \
     s|{NTASKS}|1|g; \
     s|{TIME_LIMIT}|$TIME_LIMIT|g; \
     s|{COMMANDS_FILE}|${array_commands_file}|g; \
     s|{JOB_OUTPUT_LOGS}|${JOB_OUTPUT_LOGS}|g" template.slurm > "$array_slurm_file"

rm -f template.slurm

echo "Total jobs: $total_commands"
echo ""

# For testing purposes (override with environment variable TEST_MODE=True)
TEST_MODE=${TEST_MODE:-False}

if [ "$total_commands" -gt 0 ]; then
    if [[ "$submit_now" =~ ^[Yy] ]]; then
        if command -v submit_jobs >/dev/null 2>&1; then
            if [[ "$TEST_MODE" == "True" || "$TEST_MODE" == "true" ]]; then
                echo "[TEST MODE] Would submit jobs now with: submit_jobs ${array_slurm_file} ${array_commands_file}"
                if [ "$commands_file_count" -gt 1 ]; then
                    echo "[TEST MODE] 1 of ${commands_file_count} job arrays would be submitted. Submit the remaining arrays when ${COMMANDS_FILE} completes."
                fi
            else
                echo "Submitting ${array_commands_file} to the cluster now..."
                submit_jobs "${array_slurm_file}" "${array_commands_file}"
                if [ "$commands_file_count" -gt 1 ]; then
                    echo "1 of ${commands_file_count} job arrays submitted. Submit the remaining arrays when ${COMMANDS_FILE} completes."
                fi
            fi
        else
            echo "submit_jobs not found in PATH. Run manually: submit_jobs ${array_slurm_file} ${array_commands_file}"
        fi
    else
        echo "Skipping submission. Run manually when ready: submit_jobs ${array_slurm_file} ${array_commands_file}"
    fi
else
    echo "No commands to submit."
fi


