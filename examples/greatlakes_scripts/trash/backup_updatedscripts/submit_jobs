#!/bin/bash
set +o noclobber

# Source the SCO environment configuration
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${script_dir}/sco_env.sh"

# Configuration
MAX_SUBMITTED=4999  # Maximum jobs in queue (any state)
MAX_RUNNING=1499     # Maximum jobs running/pending concurrently
POLL_INTERVAL=60    # Seconds between queue checks
USERNAME=$(whoami)

# Usage
if [ "$#" -ne 2 ]; then
  echo "Usage: $0 <array_template.slurm> <commands_file.txt>"
  echo "Example: $0 modeling_run_01_array.slurm modeling_run_01_commands.txt"
  exit 1
fi

ARRAY_TEMPLATE="$1"
COMMANDS_FILE="$2"

# Validate inputs
if [ ! -f "$ARRAY_TEMPLATE" ]; then
  echo "Error: Template file not found: $ARRAY_TEMPLATE"
  exit 1
fi

if [ ! -f "$COMMANDS_FILE" ]; then
  echo "Error: Commands file not found: $COMMANDS_FILE"
  exit 1
fi

# Normalize paths to avoid issues if cleanup runs from another working directory
WORKDIR=$(pwd)
ARRAY_TEMPLATE_ABS=$(cd "$(dirname "$ARRAY_TEMPLATE")" && pwd)/$(basename "$ARRAY_TEMPLATE")
COMMANDS_FILE_ABS=$(cd "$(dirname "$COMMANDS_FILE")" && pwd)/$(basename "$COMMANDS_FILE")

# Count total jobs
TOTAL_JOBS=$(wc -l < "$COMMANDS_FILE")
echo "Total jobs to submit: $TOTAL_JOBS"

if [ "$TOTAL_JOBS" -eq 0 ]; then
  echo "Error: No jobs found in commands file"
  exit 1
fi

# Clean out old logs
read -p "Do you want to delete old job logs? (Y/N) " answer
if [ "$answer" != "${answer#[Yy]}" ]; then
    rm -f "${JOB_OUTPUT_LOGS}"/*
    echo "Cleaned all files from job logs directory: ${JOB_OUTPUT_LOGS}"
else
    echo "Skipping log cleanup."
fi

# Function to count current jobs in queue (pending + running)
count_jobs() {
  squeue -u "$USERNAME" -h -t PD,R | wc -l
}

# Function to count current running jobs
count_running() {
  squeue -u "$USERNAME" -h -t R | wc -l
}

# Create daemon script
DAEMON_SCRIPT=".submit_jobs_daemon_$$.sh"
cat > "$DAEMON_SCRIPT" << 'DAEMON_EOF'
#!/bin/bash

# Read configuration from environment
TOTAL_JOBS=$1
MAX_SUBMITTED=$2
MAX_RUNNING=$3
POLL_INTERVAL=$4
ARRAY_TEMPLATE=$5
COMMANDS_FILE=$6
USERNAME=$7
WORKDIR=$8
DAEMON_PID=$$

LOGFILE="${WORKDIR}/.submit_jobs_daemon_${DAEMON_PID}.log"
TRACKER="${WORKDIR}/.submit_jobs_tracker_${DAEMON_PID}.txt"

echo "[$(date)] Daemon started (PID: $DAEMON_PID)" >> "$LOGFILE"
echo "[$(date)] Total jobs: $TOTAL_JOBS" >> "$LOGFILE"
echo "[$(date)] Max submitted: $MAX_SUBMITTED, Max running: $MAX_RUNNING" >> "$LOGFILE"

next_job=1

# Function to count current jobs (pending + running)
count_jobs() {
  squeue -u "$USERNAME" -h -t PD,R | wc -l
}

# Function to count current running jobs only
count_running() {
  squeue -u "$USERNAME" -h -t R | wc -l
}

# Function to submit batch
submit_batch() {
  local start=$1
  local end=$2
  local throttle=$3
  
  echo "[$(date)] Submitting jobs $start-$end with throttle %$throttle" >> "$LOGFILE"
  job_id=$(sbatch --parsable --array="$start-$end%$throttle" "$ARRAY_TEMPLATE" 2>&1)
  
  if [ $? -eq 0 ]; then
    echo "[$(date)] Submitted array job ID: $job_id" >> "$LOGFILE"
    echo "$job_id" >> "$TRACKER"
    return 0
  else
    echo "[$(date)] ERROR: Failed to submit batch $start-$end: $job_id" >> "$LOGFILE"
    return 1
  fi
}

# Block until we have capacity for first submission
while true; do
  current_jobs=$(count_jobs)
  current_running=$(count_running)
  available_submitted=$((MAX_SUBMITTED - current_jobs))
  available_running=$((MAX_RUNNING - current_running))

  if [ $available_submitted -le 0 ] || [ $available_running -le 0 ]; then
    echo "[$(date)] Waiting for capacity: queue=$current_jobs, running=$current_running" >> "$LOGFILE"
    sleep $POLL_INTERVAL
    continue
  fi

  initial_batch_size=$available_submitted
  if [ $initial_batch_size -gt $TOTAL_JOBS ]; then
    initial_batch_size=$TOTAL_JOBS
  fi

  throttle=$available_running
  if [ $throttle -lt 1 ]; then
    throttle=1
  fi

  submit_batch $next_job $((next_job + initial_batch_size - 1)) $throttle
  next_job=$((next_job + initial_batch_size))
  break
done

# Monitoring loop
while [ $next_job -le $TOTAL_JOBS ]; do
  sleep $POLL_INTERVAL
  
  current_jobs=$(count_jobs)
  current_running=$(count_running)
  available_submitted=$((MAX_SUBMITTED - current_jobs))
  available_running=$((MAX_RUNNING - current_running))
  remaining_jobs=$((TOTAL_JOBS - next_job + 1))
  
  echo "[$(date)] Status: queue=$current_jobs, running=$current_running, slots=$available_submitted, run_slots=$available_running, next job: $next_job/$TOTAL_JOBS" >> "$LOGFILE"
  
  # Need room in both submission and running budgets
  if [ $available_submitted -le 0 ] || [ $available_running -le 0 ]; then
    continue
  fi

  # Leave a small buffer (100) in submission budget when possible
  batch_size=$available_submitted
  if [ $batch_size -gt 100 ]; then
    batch_size=$((batch_size - 100))
  fi
  if [ $batch_size -gt $remaining_jobs ]; then
    batch_size=$remaining_jobs
  fi

  throttle=$available_running
  if [ $throttle -lt 1 ]; then
    throttle=1
  fi

  if [ $batch_size -gt 0 ]; then
    batch_end=$((next_job + batch_size - 1))
    submit_batch $next_job $batch_end $throttle
    next_job=$((next_job + batch_size))
  fi
done

echo "[$(date)] All jobs submitted! Daemon exiting." >> "$LOGFILE"
echo "[$(date)] Use 'squeue -u $USERNAME' to check job status." >> "$LOGFILE"


DAEMON_EOF

chmod +x "$DAEMON_SCRIPT"

# Launch daemon in background
echo "Starting submission daemon..."
nohup "$DAEMON_SCRIPT" "$TOTAL_JOBS" "$MAX_SUBMITTED" "$MAX_RUNNING" "$POLL_INTERVAL" "$ARRAY_TEMPLATE_ABS" "$COMMANDS_FILE_ABS" "$USERNAME" "$WORKDIR" > /dev/null 2>&1 &
DAEMON_PID=$!

echo "Daemon started with PID: $DAEMON_PID"
echo "Log file: .submit_jobs_daemon_${DAEMON_PID}.log"
echo "Tracker file: .submit_jobs_tracker_${DAEMON_PID}.txt"
echo ""
echo "The daemon will continue running in the background even if you disconnect."
echo "Monitor progress with: tail -f .submit_jobs_daemon_${DAEMON_PID}.log"
echo "Check queue status: squeue -u $USERNAME"
echo ""
echo "To kill the daemon if needed: kill $DAEMON_PID"
echo "Output and error logs are located in: ${JOB_OUTPUT_LOGS}/"
