#!/bin/bash
set +o noclobber

# Parameters
input_file=$1
wavefitmin=$2
wavefitmax=$3
redshift=$4
velocity=100 # Placeholder: velocity can be customized if required later
spectrograph=$5
smoothing=$6

# Set wavemin and step based on the spectrograph
case $spectrograph in
    muse)
        wavemin=4750
        step=1.25
        ;;
    stis)
        wavemin=8275.0
        step=0.55859375
        ;;
    *)
        echo "Invalid spectrograph. Please enter 'muse' or 'stis'."
        exit 1
        ;;
esac

# Generate input for the Fortran script
# Source the SCO environment configuration if not already sourced
if [ -z "$SCO_FRAMEWORK_BIN" ]; then
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    source "${script_dir}/sco_env.sh"
fi

"${SCO_FRAMEWORK_BIN}/fitlovw" << eof
${input_file}.norm
${input_file}
${wavemin} ${step}
0 0
Tlist
${wavemin} ${step}
0 0
${wavefitmin} ${wavefitmax}
${redshift} ${velocity}
${smoothing}
2e-5
0
0
/vcps
eof

if [ -f ascii.out ]; then
   cp ascii.out ${input_file}.ascii
fi

if [ -f rms.out ]; then
   cp rms.out ${input_file}.rms
fi

if [ -f fitlov.out ]; then
   cp fitlov.out ${input_file}.fit
fi

if [ -f fitlov.temp ]; then
   cp fitlov.temp ${input_file}.temp
fi

if [ -f pgplot.ps ]; then
   cp pgplot.ps ${input_file}_fitlov.ps
fi
