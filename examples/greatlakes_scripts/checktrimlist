#!/bin/bash

# Debug script to check for duplicates and analyze the trimlist behavior

inlist=$1

if [ -z "${inlist}" ] || [ ! -f "${inlist}" ]; then
    echo "Usage: $0 <run_list_file>" >&2
    exit 1
fi

echo "=== Analyzing ${inlist} ==="
echo ""

# Check total lines in input
total_lines=$(wc -l < "${inlist}")
echo "Total lines in input file: ${total_lines}"

# Check for duplicate lines in input file
unique_lines=$(sort "${inlist}" | uniq | wc -l)
duplicate_count=$((total_lines - unique_lines))
echo "Unique lines: ${unique_lines}"
echo "Duplicate lines: ${duplicate_count}"
echo ""

# Generate the filename lists
awk '{print "cres.m"$2"b"$4"v"$5"r"$6"i"$8"x"$3}' "${inlist}" > /tmp/creslist_debug
awk '{print "res.m"$2"b"$4"v"$5"r"$6"i"$8"x"$3}' "${inlist}" > /tmp/reslist_debug
awk '{print "iter.m"$2"b"$4"v"$5"r"$6"i"$8"x"$3}' "${inlist}" > /tmp/iterlist_debug
awk '{print "gherm.m"$2"b"$4"v"$5"r"$6"i"$8"x"$3}' "${inlist}" > /tmp/ghermlist_debug

# Check for duplicates in generated filename lists
echo "=== Checking generated filename lists ==="
cres_total=$(wc -l < /tmp/creslist_debug)
cres_unique=$(sort /tmp/creslist_debug | uniq | wc -l)
echo "cres filenames - Total: ${cres_total}, Unique: ${cres_unique}, Duplicates: $((cres_total - cres_unique))"

res_total=$(wc -l < /tmp/reslist_debug)
res_unique=$(sort /tmp/reslist_debug | uniq | wc -l)
echo "res filenames - Total: ${res_total}, Unique: ${res_unique}, Duplicates: $((res_total - res_unique))"

iter_total=$(wc -l < /tmp/iterlist_debug)
iter_unique=$(sort /tmp/iterlist_debug | uniq | wc -l)
echo "iter filenames - Total: ${iter_total}, Unique: ${iter_unique}, Duplicates: $((iter_total - iter_unique))"

gherm_total=$(wc -l < /tmp/ghermlist_debug)
gherm_unique=$(sort /tmp/ghermlist_debug | uniq | wc -l)
echo "gherm filenames - Total: ${gherm_total}, Unique: ${gherm_unique}, Duplicates: $((gherm_total - gherm_unique))"
echo ""

# Check how many of these files actually exist in res/
current_dir=$(pwd)
echo "=== Checking file existence in ${current_dir}/res/ ==="

existing_cres=0
missing_cres=0
mapfile -t creslist < /tmp/creslist_debug
for cres in "${creslist[@]}"; do
    if [ -e "${current_dir}/res/$cres" ] && [ -s "${current_dir}/res/$cres" ]; then
        ((existing_cres++))
    else
        ((missing_cres++))
    fi
done

echo "cres files - Existing: ${existing_cres}, Missing: ${missing_cres}"

existing_complete=0
missing_any=0
mapfile -t reslist < /tmp/reslist_debug
mapfile -t iterlist < /tmp/iterlist_debug
mapfile -t ghermlist < /tmp/ghermlist_debug

for i in "${!creslist[@]}"; do
    cres="${creslist[$i]}"
    res="${reslist[$i]}"
    iter="${iterlist[$i]}"
    gherm="${ghermlist[$i]}"

    if [ -e "${current_dir}/res/$cres" ] && [ -s "${current_dir}/res/$cres" ] && \
       [ -e "${current_dir}/res/$res" ] && [ -s "${current_dir}/res/$res" ] && \
       [ -e "${current_dir}/res/$iter" ] && [ -s "${current_dir}/res/$iter" ] && \
       [ -e "${current_dir}/res/$gherm" ] && [ -s "${current_dir}/res/$gherm" ]; then
        ((existing_complete++))
    else
        ((missing_any++))
    fi
done

echo "Complete runs (all 4 files exist): ${existing_complete}"
echo "Incomplete runs (any file missing): ${missing_any}"
echo ""

echo "=== Expected behavior ==="
echo "After trimlist, ${existing_complete} complete runs should be removed"
echo "Resulting file should have ${missing_any} lines (incomplete runs to rerun)"

# Clean up
rm -f /tmp/creslist_debug /tmp/reslist_debug /tmp/iterlist_debug /tmp/ghermlist_debug

