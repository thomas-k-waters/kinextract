#!/bin/bash
set +o noclobber

# Source the SCO environment configuration
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${script_dir}/sco_env.sh"

name=$1

# Remove any existing ftoa.out file
rm -f ftoa.out

# Run the ftoa Fortran executable with the provided FITS file name
"${SCO_FRAMEWORK_BIN}/ftoa" << eof
${name}.fits
1
eof

# Move the output file to the desired name
if [ -e ftoa.out ]; then
    mv ftoa.out ${name}.ftoa
else
    echo "Error: ftoa.out not found."
    exit 1
fi
