#!/bin/bash
set +o noclobber

# Source the SCO environment configuration
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${script_dir}/sco_env.sh"

# Get the current directory where the script is being run
current_dir=$(pwd)

# Config file to store last inputs
config_file="${current_dir}/.lastinput"

# Prompt Function for user inputs
prompt_with_default() {
    local prompt_message=$1
    local default_value=$2
    read -p "$prompt_message [${default_value}]: " input_value
    if [ -z "$input_value" ]; then
        input_value=$default_value
    fi
    echo $input_value
}

# Load previous script inputs if the config file exists
if [[ -f $config_file ]]; then
    source $config_file
else
    last_galaxy=""
    last_distance=""
    last_Upsilon_guess=""
    last_M_bh=""
    last_photometric_band=""
    last_effective_radius=""
    last_apparent_q=""
    last_true_q=""
fi


# Prompt for user inputs
galaxy=$(prompt_with_default "Enter the galaxy name" $last_galaxy)
if [ -z "$galaxy" ]; then
    echo "Galaxy must be provided."
    exit 1
fi

distance=$(prompt_with_default "Enter the distance to the galaxy in Mpc" $last_distance)
if [ -z "$distance" ]; then
    echo "Distance must be provided."
    exit 1
fi

Upsilon_guess=$(prompt_with_default "Enter a reasonable guess for M/L" $last_Upsilon_guess)
if [ -z "$Upsilon_guess" ]; then
    echo "M/L must be provided."
    exit 1
fi

M_bh=$(prompt_with_default "Enter a guess for the black hole mass in solar masses (0 if none)" $last_M_bh)
if [ -z "$M_bh" ]; then
    echo "Black hole mass must be provided."
    exit 1
fi

photometric_band=$(prompt_with_default "Enter the photometric band of the SB profile" $last_photometric_band)
if [ -z "$photometric_band" ]; then
    echo "Photometric band must be provided."
    exit 1
fi

effective_radius=$(prompt_with_default "Enter the effective radius in arcseconds" $last_effective_radius)
if [ -z "$effective_radius" ]; then
    echo "Effective radius must be provided."
    exit 1
fi

# Function to exit the script
exit_function() {
    echo "The surface brightness profile analysis for ${galaxy} is complete! Continue by navigating to the kinematics directory (below) and running the binspectra command."

    # Prefer a path resolved from the actual directory structure where this script ran.
    # Expected run location is: <analysis_root>/<galaxy>/sb_analysis
    kin_dir_from_tree="$(cd "${current_dir}/.." 2>/dev/null && pwd)/kinematics"
    kin_dir_from_input="$(sco_get_galaxy_path "$galaxy")/kinematics"

    if [ -d "$kin_dir_from_tree" ]; then
        echo "Kinematics directory: $kin_dir_from_tree"
        echo "Command: cd $kin_dir_from_tree"
    elif [ -d "$kin_dir_from_input" ]; then
        echo "Kinematics directory: $kin_dir_from_input"
        echo "Command: cd $kin_dir_from_input"
    else
        echo "Warning: Could not find a valid kinematics directory using either path strategy."
        echo "From current tree: $kin_dir_from_tree"
        echo "From galaxy input: $kin_dir_from_input"
    fi

    exit 0
}

###########################################
# Surface brightness profile deprojection #
###########################################

sb_deproject() {

    cd "${current_dir}/deprojection" || { echo "Failed to cd"; exit 1; }

    file=$(ls sb.use 2> /dev/null)
    if [ -z "$file" ]; then
        echo "Missing surface brightness profile (sb.use). Exiting..."
        exit 1
    fi

    rnpdyn "$distance" "$effective_radius" "$Upsilon_guess" "$M_bh" "$photometric_band" "$galaxy" >> out
    rm -f out npdyn.def

    # Interactive gdenconv loop
    apparent_q=$last_apparent_q
    true_q=$last_true_q
    local happy_with_inclination="n"

    while [[ "$happy_with_inclination" != "y" ]]; do
        # Prompt user for axis ratios
        apparent_q=$(prompt_with_default "Enter the apparent axis ratio" "$apparent_q")
        true_q=$(prompt_with_default "Enter the true axis ratio" "$true_q")
        # Call gdenconv with axis ratios, capture output
        # Use a temp file to avoid collision
        tmp_out=$(mktemp)
        gdenconv <<EOF > "$tmp_out"
npdyn.out
$apparent_q $true_q
EOF

        # Print the inclination value to the user by parsing output
	inclination_value=$(grep -i "inclination" "$tmp_out" | sed -n 's/.*inclination = *\([-.0-9eE]*\).*/\1/p')
        echo "i=$inclination_value"

        # Ask user if they wish to keep this value
        read -p "Are you happy with this inclination? (y/n): " happy_with_inclination
        if [[ -z "$happy_with_inclination" ]]; then
            happy_with_inclination="y"
        fi

        rm -f "$tmp_out"
    done

    cat > "$config_file" <<EOF
last_galaxy="$galaxy"
last_distance="$distance"
last_Upsilon_guess="$Upsilon_guess"
last_M_bh="$M_bh"
last_photometric_band="$photometric_band"
last_effective_radius="$effective_radius"
last_apparent_q="$apparent_q"
last_true_q="$true_q"
EOF

    mkdir -p "${current_dir}/deprojection/deprojection.outputs"
    cp gden.out "${current_dir}/binning/gden.use"
    mv *.out "${current_dir}/deprojection/deprojection.outputs"
    mv pgplot.ps "${current_dir}/deprojection/deprojection.outputs/${galaxy}.npdyn.ps"
}
sb_deproject


###########################################
# Surface brightness profile binning  #
###########################################

sb_binning() {

    cd "${current_dir}/binning" || { echo "Failed to cd"; exit 1; }

    file=$(ls gden.use 2> /dev/null)
    if [ -z "$file" ]; then
        echo "Missing surface brightness profile (gden.use). Exiting..."
        exit 1
    fi
    if [ ! -f galaxy.params ]; then
        echo "Creating galaxy.params file..."
        cat <<EOF > galaxy.params
NGC5102
distanceMpc  3.66
angleRmax     90
vmin         -300.
vmax          300.
slope_0       -1.0
MtoL          10.
islitsize     0  (0=nothing; 1=0.1"x0.2"; 2=0.1"x0.1" (HST))
EOF
    fi

    rgden "$inclination_value" "$Upsilon_guess" >> out
    rm -f out
    mv *.out "${current_dir}/binning/binning.outputs/"
    mv *.dat "${current_dir}/binning/binning.outputs/"
    mv *.norm "${current_dir}/binning/binning.outputs/"


}
sb_binning
exit_function
