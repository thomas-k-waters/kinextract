#!/bin/bash
set +o noclobber

# This command makes a new modeling run list for jobs that were incomplete in your main
# run because you didn't request enough time or memory.

inlist=$1 # original run list

# Basic usage/argument checks
if [ -z "${inlist}" ] || [ ! -f "${inlist}" ]; then
    echo "Usage: $0 <run_list_file>" >&2
    exit 1
fi

current_dir=$(pwd)
res_dir="${current_dir}/res"

# Work on a temporary file and overwrite the input at the end
work_file=$(mktemp -t trimlist.XXXXXXXX)

# Single pass through the input file: check each run's completion status
# and only write incomplete runs to the work file
awk -v resdir="${res_dir}" '
BEGIN {
    cmd = "find " resdir " -name cres.m* -size +0c"
    while ((cmd | getline file) > 0) {
        # Extract filename without path
        sub(/.*\//, "", file)
        complete_files[file] = 1
    }
    close(cmd)
    
    # Check res, iter, gherm files
    cmd = "find " resdir " -name res.m* -size +0c"
    while ((cmd | getline file) > 0) {
        sub(/.*\//, "", file)
        res_files[file] = 1
    }
    close(cmd)
    
    cmd = "find " resdir " -name iter.m* -size +0c"
    while ((cmd | getline file) > 0) {
        sub(/.*\//, "", file)
        iter_files[file] = 1
    }
    close(cmd)
    
    cmd = "find " resdir " -name gherm.m* -size +0c"
    while ((cmd | getline file) > 0) {
        sub(/.*\//, "", file)
        gherm_files[file] = 1
    }
    close(cmd)
}
{
    # Build the expected filenames for this run
    cres = "cres.m" $2 "b" $4 "v" $5 "r" $6 "i" $8 "x" $3
    res = "res.m" $2 "b" $4 "v" $5 "r" $6 "i" $8 "x" $3
    iter = "iter.m" $2 "b" $4 "v" $5 "r" $6 "i" $8 "x" $3
    gherm = "gherm.m" $2 "b" $4 "v" $5 "r" $6 "i" $8 "x" $3
    
    # Check if all required files exist
    if (!(cres in complete_files) || !(res in res_files) || \
        !(iter in iter_files) || !(gherm in gherm_files)) {
        # Run is incomplete, keep it
        print $0
    } else {
        # Run is complete, skip it (do not print)
        complete_count++
    }
}
END {
    print "Complete runs found: " complete_count > "/dev/stderr"
}
' "${inlist}" > "$work_file"

len_old=$(wc -l < "${inlist}")
len_new=$(wc -l < "$work_file")

if [ "$len_old" != "$len_new" ]; then
    lines_trimmed=$((len_old - len_new))
    if [ "$len_new" -le 1 ]; then
        echo "All runs have already been completed. No changes made."
        rm -f "$work_file"
    else
        echo "$lines_trimmed lines were trimmed."
        mv "$work_file" "${inlist}"
    fi
else
    echo "All runs are unique. No lines trimmed."
    rm -f "$work_file"
fi

# Final summary line with number of entries
final_len=$(wc -l < "${inlist}")
echo "Saved ${inlist} file with ${final_len} entries."
